# Copy this file to .env and fill in your real values.
# DB_TYPE decides which database the whole backend talks to.
# Valid values: mysql | postgres | mongodb
DB_TYPE=mysql

PORT=4000

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=brainiac_quizzes

# --- PostgreSQL ---
PG_HOST=localhost
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=brainiac_quizzes
PG_PORT=5432

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=brainiac_quizzes
