# Copy this file to .env and fill in your real values.
# DB_TYPE decides which database the whole backend talks to.
# Valid values: mysql | postgres | mongodb
DB_TYPE=mysql

PORT=4000

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=brainiac_quizzes

# --- PostgreSQL ---
PG_HOST=localhost
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=brainiac_quizzes
PG_PORT=5432

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=brainiac_quizzes

# --- Email (for "forgot password" reset links) ---
# Leave SMTP_HOST blank during local development — reset links print to the
# server's console instead of emailing, so you can still test the flow.
# For Gmail: host smtp.gmail.com, port 587, and an "app password" (not your
# normal Gmail password) — Google requires this for third-party apps.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# The public URL of your frontend, used to build the link inside reset emails
APP_URL=http://localhost:8000
